# ===========================================================================
# Test Environment Configuration
# ===========================================================================
# Used by: apps/api/tests/setup.ts, Makefile test targets, Playwright
#
# Ports are offset from dev to avoid conflicts:
#   Postgres: 5433 (dev uses 5432)
#   Redis:    6380 (dev uses 6379)
#   MinIO:    9002 (dev uses 9000)
#
# Start test infrastructure:  make test-infra
# Run all tests:               make test-all
# ===========================================================================

NODE_ENV=test

# Database — matches docker-compose.test.yml
DATABASE_URL=postgresql://smoker:smoker_dev@localhost:5433/smoker_test

# Redis — matches docker-compose.test.yml
REDIS_URL=redis://localhost:6380/1

# API Server
PORT=4000
HOST=0.0.0.0
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# JWT — deterministic test secrets
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5

# Twilio — fake credentials (OTP tests mock the Twilio client)
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_FROM_NUMBER=+15555555555

# S3 / MinIO — matches docker-compose.test.yml minio service
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_BUCKET=smoker-test-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FILE_DOMAIN=http://localhost:9002/smoker-test-files

# PII Encryption — deterministic 32-byte hex key
PII_ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Invite Token HMAC
INVITE_HMAC_SECRET=test-hmac-secret-at-least-32-chars-long

# Sentry — disabled in tests
# SENTRY_DSN=

# Metrics — no auth in test
# METRICS_TOKEN=
