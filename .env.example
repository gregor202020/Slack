# Database
DATABASE_URL=postgresql://smoker:smoker_dev@localhost:5432/smoker

# API Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5

# Twilio (SMS for OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# DigitalOcean Spaces (S3-compatible file storage)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=smoker-files
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FILE_DOMAIN=

# Local MinIO defaults (uncomment for local dev with Docker):
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=smoker-files
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FILE_DOMAIN=http://localhost:9000/smoker-files

# PII Encryption
PII_ENCRYPTION_KEY=change-this-to-a-random-32-byte-hex-string

# Invite Token HMAC
INVITE_HMAC_SECRET=change-this-to-a-random-64-char-string

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000
