# Copy to .env and fill in values
DATABASE_URL=postgresql://smoker:smoker_dev@localhost:5432/smoker
REDIS_URL=redis://localhost:6379
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
JWT_SECRET=dev-secret-change-in-production-must-be-at-least-32-chars
PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
INVITE_HMAC_SECRET=dev-hmac-secret-change-in-production

# Error Tracking (optional — leave commented out to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Logging (optional)
# LOG_FILE=./logs/api.log
# LOG_MAX_SIZE=10m
