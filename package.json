{
  "name": "the-smoker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@smoker/db",
    "db:migrate": "turbo run db:migrate --filter=@smoker/db",
    "db:seed": "turbo run db:seed --filter=@smoker/db",
    "db:studio": "turbo run db:studio --filter=@smoker/db",
    "test": "turbo run test",
    "test:api": "npm run test -w @smoker/api",
    "test:mobile": "npm run test -w @smoker/mobile",
    "test:e2e": "npx playwright test -c apps/web/playwright.config.ts --project=chromium",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:test": "k6 run load-tests/load.js",
    "load:stress": "k6 run load-tests/stress.js",
    "load:spike": "k6 run load-tests/spike.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "eslint": "^9.18.0"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
