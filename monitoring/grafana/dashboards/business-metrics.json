      "title": "Requests / Hour",
      "description": "Total HTTP requests over the last hour, providing a high-level throughput view.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[1h]))",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Messaging Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "messages/hr",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Messages Sent per Hour",
      "description": "Hourly count of POST requests to message endpoints — an estimate of messaging volume.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{method=\"POST\", route=~\"/api/channels/.*/messages.*\"}[1h]))",
          "legendFormat": "Messages",
          "refId": "A"
        }
      ]
    },
